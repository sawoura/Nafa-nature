<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Le Secret des Cheveux Crépus — Nafissatou Sawoura</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold:        #C9A84C;
    --gold-light:  #E8D08A;
    --gold-pale:   #F8EFD4;
    --brown-deep:  #1E0F06;
    --brown-mid:   #3D1F0D;
    --brown-warm:  #5C3317;
    --cream:       #FDF8F0;
    --cream-warm:  #F5ECD8;
    --green:       #3B6B4A;
    --green-light: #EAF2EC;
    --white:       #FFFFFF;
    --text-main:   #2C1810;
    --text-muted:  #7A5C45;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--cream);
    color: var(--text-main);
    overflow-x: hidden;
  }

  /* ─── HERO ─────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    background: linear-gradient(160deg, var(--brown-deep) 0%, var(--brown-mid) 55%, #2E1208 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 60px 20px;
  }

  /* Texture dots */
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(201,168,76,0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* Gold glow */
  .hero::after {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* Book mockup */
  .book-mockup {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-shadow {
    position: absolute;
    width: 200px; height: 20px;
    background: rgba(0,0,0,0.4);
    bottom: -10px; left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    filter: blur(10px);
  }

  .book-3d {
    width: 200px;
    height: 270px;
    position: relative;
    transform-style: preserve-3d;
    transform: perspective(800px) rotateY(-20deg) rotateX(3deg);
    animation: float 4s ease-in-out infinite;
    filter: drop-shadow(0 30px 40px rgba(0,0,0,0.6));
  }

  @keyframes float {
    0%, 100% { transform: perspective(800px) rotateY(-20deg) rotateX(3deg) translateY(0px); }
    50%       { transform: perspective(800px) rotateY(-20deg) rotateX(3deg) translateY(-12px); }
  }

  .book-face {
    width: 200px;
    height: 270px;
    background: linear-gradient(160deg, #1E0F06 0%, #2C1810 40%, #3D1F0D 100%);
    border-radius: 3px 10px 10px 3px;
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px 16px;
    border: 1px solid rgba(201,168,76,0.4);
    overflow: hidden;
  }

  .book-face::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 2px 8px 8px 2px;
    pointer-events: none;
  }

  .book-top-band {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 18px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
  }

  .book-bottom-band {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 18px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
  }

  .book-content {
    text-align: center;
    z-index: 1;
    margin-top: 8px;
  }

  .book-stars {
    color: var(--gold);
    font-size: 10px;
    letter-spacing: 3px;
    margin-bottom: 10px;
  }

  .book-title-small {
    font-family: 'Playfair Display', serif;
    font-size: 9px;
    font-weight: 400;
    color: var(--gold-light);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .book-title-main {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 900;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .book-title-sub {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .book-line {
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 10px;
  }

  .book-subtitle {
    font-size: 7.5px;
    color: rgba(255,255,255,0.6);
    text-align: center;
    line-height: 1.5;
    font-style: italic;
    margin-bottom: 12px;
  }

  .book-author {
    font-family: 'Playfair Display', serif;
    font-size: 8px;
    color: var(--gold);
    letter-spacing: 1.5px;
    font-style: italic;
  }

  .book-spine {
    width: 22px;
    height: 270px;
    background: linear-gradient(180deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
    position: absolute;
    left: -22px;
    top: 0;
    border-radius: 3px 0 0 3px;
    transform-origin: right;
    transform: rotateY(90deg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-spine-text {
    font-family: 'Playfair Display', serif;
    font-size: 7px;
    font-weight: 700;
    color: var(--brown-deep);
    writing-mode: vertical-rl;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .badge-floating {
    position: absolute;
    top: -16px;
    right: -16px;
    width: 72px; height: 72px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(201,168,76,0.5);
    z-index: 10;
  }

  .badge-floating span:first-child {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 900;
    color: var(--brown-deep);
    line-height: 1;
  }

  .badge-floating span:last-child {
    font-size: 7px;
    font-weight: 700;
    color: var(--brown-deep);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Hero text */
  .hero-text { color: var(--white); }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
    width: 20px;
  }

  .hero-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 900;
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 8px;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 400;
    font-style: italic;
    color: rgba(255,255,255,0.65);
    margin-bottom: 28px;
    line-height: 1.5;
  }

  .hero-promise {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    margin-bottom: 32px;
    border-left: 2px solid var(--gold);
    padding-left: 14px;
  }

  .hero-promise strong { color: var(--gold-light); }

  .cta-group { display: flex; flex-direction: column; gap: 12px; }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 32px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: var(--brown-deep);
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 30px rgba(201,168,76,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    letter-spacing: 0.3px;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(201,168,76,0.55);
  }

  .cta-primary .arrow { font-size: 18px; }

  .cta-meta {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    text-align: center;
    letter-spacing: 0.3px;
  }

  .trust-row {
    display: flex;
    gap: 20px;
    margin-top: 4px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    color: rgba(255,255,255,0.55);
  }

  .trust-item .icon { color: var(--gold); font-size: 13px; }

  /* ─── SOCIAL PROOF BAR ─────────────────────────────────── */
  .proof-bar {
    background: var(--brown-warm);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(201,168,76,0.2);
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }

  .proof-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--white);
  }

  .proof-icon { font-size: 20px; }

  .proof-text { font-size: 12px; color: rgba(255,255,255,0.7); }
  .proof-text strong { display: block; color: var(--white); font-size: 14px; font-weight: 600; }

  /* ─── SECTIONS ─────────────────────────────────────────── */
  section { padding: 80px 20px; }

  .container { max-width: 860px; margin: 0 auto; }

  .section-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 900;
    color: var(--brown-deep);
    text-align: center;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .section-lead {
    text-align: center;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 50px;
  }

  /* ─── PAIN SECTION ─────────────────────────────────────── */
  .pain-section { background: var(--cream-warm); }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }

  .pain-card {
    background: var(--white);
    border-radius: 8px;
    padding: 20px;
    border-left: 3px solid #E53935;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .pain-icon { font-size: 22px; margin-bottom: 8px; }
  .pain-text { font-size: 13px; color: var(--text-main); line-height: 1.6; }

  .transition-promise {
    background: linear-gradient(135deg, var(--brown-deep), var(--brown-mid));
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    color: var(--white);
  }

  .transition-promise p {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-style: italic;
    line-height: 1.5;
  }

  .transition-promise p em { color: var(--gold); font-style: normal; font-weight: 700; }

  /* ─── CONTENT ─────────────────────────────────────────── */
  .content-section { background: var(--white); }

  .chapters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }

  .chapter-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    border-radius: 8px;
    background: var(--cream);
    border: 1px solid rgba(201,168,76,0.2);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .chapter-card:hover {
    border-color: var(--gold);
    box-shadow: 0 4px 20px rgba(201,168,76,0.15);
  }

  .ch-num {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    min-width: 32px;
  }

  .ch-info { flex: 1; }
  .ch-title { font-size: 13px; font-weight: 600; color: var(--brown-deep); line-height: 1.4; }

  /* ─── BONUS ─────────────────────────────────────────────── */
  .bonus-section { background: var(--brown-deep); }

  .bonus-section .section-title { color: var(--white); }
  .bonus-section .section-lead { color: rgba(255,255,255,0.55); }

  .bonus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 16px;
  }

  .bonus-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 10px;
    padding: 22px;
    transition: background 0.2s, border-color 0.2s;
  }

  .bonus-card:hover {
    background: rgba(201,168,76,0.08);
    border-color: var(--gold);
  }

  .bonus-icon { font-size: 26px; margin-bottom: 10px; }
  .bonus-title { font-size: 14px; font-weight: 600; color: var(--gold-light); margin-bottom: 4px; }
  .bonus-desc { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* ─── AUTHOR ─────────────────────────────────────────────── */
  .author-section { background: var(--cream-warm); }

  .author-inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
    align-items: center;
  }

  .author-avatar {
    width: 160px; height: 160px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brown-mid), var(--brown-deep));
    border: 4px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
  }

  .author-avatar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.1), transparent);
    border-radius: 50%;
  }

  .author-name {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--brown-deep);
    margin-bottom: 4px;
  }

  .author-role {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .author-bio {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* ─── TESTIMONIALS ─────────────────────────────────────── */
  .testimonials-section { background: var(--white); }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .testimonial-card {
    padding: 24px;
    border-radius: 10px;
    background: var(--cream);
    border: 1px solid var(--gold-pale);
    position: relative;
  }

  .testimonial-card::before {
    content: '"';
    font-family: 'Playfair Display', serif;
    font-size: 72px;
    line-height: 1;
    color: var(--gold);
    opacity: 0.2;
    position: absolute;
    top: 8px; left: 16px;
  }

  .testimonial-stars { color: var(--gold); font-size: 13px; margin-bottom: 12px; }

  .testimonial-text {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .testimonial-author { font-size: 12px; font-weight: 600; color: var(--brown-mid); }
  .testimonial-location { font-size: 11px; color: var(--text-muted); }

  /* ─── PRICING ─────────────────────────────────────────── */
  .pricing-section {
    background: linear-gradient(160deg, var(--brown-deep) 0%, #2E1208 100%);
    position: relative;
    overflow: hidden;
  }

  .pricing-section::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(201,168,76,0.06) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .pricing-section .section-title { color: var(--white); position: relative; }
  .pricing-section .section-lead { color: rgba(255,255,255,0.5); position: relative; }

  .pricing-card {
    max-width: 480px;
    margin: 0 auto;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    position: relative;
    backdrop-filter: blur(10px);
  }

  .pricing-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--brown-deep);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 20px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .price-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 8px;
    margin-top: 10px;
  }

  .price-amount {
    font-family: 'Playfair Display', serif;
    font-size: 56px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
  }

  .price-currency {
    font-size: 20px;
    font-weight: 400;
    vertical-align: super;
  }

  .price-unit {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 28px;
  }

  .price-includes {
    text-align: left;
    margin-bottom: 32px;
  }

  .price-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .price-item .check { color: var(--gold); font-size: 15px; }

  .cta-big {
    display: block;
    width: 100%;
    padding: 20px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: var(--brown-deep);
    font-size: 16px;
    font-weight: 800;
    text-decoration: none;
    border-radius: 8px;
    letter-spacing: 0.3px;
    box-shadow: 0 10px 40px rgba(201,168,76,0.4);
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-bottom: 16px;
  }

  .cta-big:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 50px rgba(201,168,76,0.55);
  }

  .cta-sub {
    font-size: 11.5px;
    color: rgba(255,255,255,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-sub span { display: flex; align-items: center; gap: 4px; }

  /* ─── FAQ ─────────────────────────────────────────────── */
  .faq-section { background: var(--cream-warm); }

  .faq-list { max-width: 640px; margin: 0 auto; }

  .faq-item {
    border-bottom: 1px solid rgba(201,168,76,0.25);
    overflow: hidden;
  }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    padding: 18px 0;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--brown-deep);
    text-align: left;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .faq-q .chevron {
    color: var(--gold);
    font-size: 18px;
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  .faq-q.open .chevron { transform: rotate(180deg); }

  .faq-a {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.8;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
    padding: 0;
  }

  .faq-a.open { max-height: 300px; padding-bottom: 16px; }

  /* ─── FOOTER ─────────────────────────────────────────── */
  .footer {
    background: var(--brown-deep);
    padding: 40px 20px;
    text-align: center;
  }

  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .footer-tagline {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 20px;
    letter-spacing: 1px;
  }

  .footer-copy {
