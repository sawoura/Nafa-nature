  /* ─── STICKY CTA ─────────────────────────────────────── */
  .sticky-cta {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--brown-deep);
    border-top: 1px solid rgba(201,168,76,0.3);
    padding: 12px 20px;
